bool pal(long long n){
    long long t = n, r = 0;

    while(t){
        r = r * 10 + (t % 10);
        t /= 10;
    }

    return r == n;
}

int main() {

    ios::sync_with_stdio(0);
    cin.tie(0);

    long long ans = 0;

    for(int i = 100; i <= 999; i++){
        for(int j = 100; j <= 999; j++){

            long long p = 1LL * i * j;

            if(pal(p)){
                ans = max(ans, p);
            }
        }
    }

    cout << ans;
}



