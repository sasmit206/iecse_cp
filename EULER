int main(){

    const int N = 2000000;

    vector<bool> prime(N, true);
    prime[0] = prime[1] = false;

    for(long long i = 2; i * i < N; i++){
        if(prime[i]){
            for(long long j = i * i; j < N; j += i){
                prime[j] = false;
            }
        }
    }

    long long sum = 0;

    for(int i = 2; i < N; i++){
        if(prime[i]) sum += i;
    }

    cout << sum;
}
