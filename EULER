bool prime(long long n){

    if(n < 2) return false;

    for(long long i = 2; i * i <= n; i++){
        if(n % i == 0) return false;
    }

    return true;
}

int main(){

    int count = 0;
    long long i = 2;

    while(true){

        if(prime(i)){
            count++;
        }

        if(count == 10001){
            cout << i;
            break;
        }

        i++;
    }
}



